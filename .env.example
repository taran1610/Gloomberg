# Gloomberg Configuration

# OpenAI API Key (optional - app works without it in offline mode)
OPENAI_API_KEY=

# OpenAI model to use
OPENAI_MODEL=gpt-4o-mini

# Redis URL (optional locally; recommended in production for faster loads)
# See docs/REDIS_SETUP.md for Upstash/Redis Cloud free tier
REDIS_URL=redis://localhost:6379

# PostgreSQL URL
DATABASE_URL=postgresql+asyncpg://gloomberg:gloomberg@localhost:5432/gloomberg

# Cache TTLs (seconds)
CACHE_TTL_DASHBOARD=300
CACHE_TTL_TICKER=900
CACHE_TTL_HISTORY=3600
CACHE_TTL_NEWS=1800

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production

# Stripe (leave empty to disable billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
FRONTEND_URL=http://localhost:3000

# SEC EDGAR identity (required for edgartools - use your email)
EDGAR_IDENTITY=gloomberg@example.com
