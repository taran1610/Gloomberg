# Backend
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# PostgreSQL (optional for full MVP; chat sessions can run in-memory)
# DATABASE_URL=postgresql+asyncpg://gloomberg:gloomberg@localhost:5432/gloomberg

# Redis (optional; cache is skipped if Redis is down)
REDIS_URL=redis://localhost:6379/0

# OpenAI-compatible LLM (required for AI research and strategy generation)
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: Alpha Vantage
# ALPHA_VANTAGE_API_KEY=
